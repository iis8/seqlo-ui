{
  "name": "@seqlo/ui",
  "version": "0.1.1",
  "description": "Seqlo UI - Vue 3 + Element Plus 业务组件库（MTable / MForm / MDescriptions / SearchBar / FieldEditor）",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iis8/seqlo-ui.git"
  },
  "bugs": {
    "url": "https://github.com/iis8/seqlo-ui/issues"
  },
  "homepage": "https://github.com/iis8/seqlo-ui#readme",
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/seqlo-ui.umd.cjs",
  "module": "./dist/seqlo-ui.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/seqlo-ui.js",
      "require": "./dist/seqlo-ui.umd.cjs"
    },
    "./styles": "./dist/style.css",
    "./src/*": "./src/*"
  },
  "sideEffects": [
    "*.scss",
    "*.css"
  ],
  "scripts": {
    "build": "vue-tsc --noEmit && vite build",
    "build:only": "vite build",
    "dev": "vite build --watch"
  },
  "peerDependencies": {
    "vue": "^3.4.0",
    "element-plus": "^2.6.0",
    "lodash-es": "^4.17.21",
    "sortablejs": "^1.15.0",
    "vue-router": "^4.3.0",
    "vue-i18n": "^9.14.0"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/sortablejs": "^1.15.9",
    "@vitejs/plugin-vue": "^5.0.4",
    "element-plus": "^2.6.1",
    "lodash-es": "^4.17.21",
    "sass": "^1.71.1",
    "sortablejs": "^1.15.7",
    "typescript": "^5.4.2",
    "vite": "^5.1.6",
    "vite-plugin-dts": "^3.9.1",
    "vue": "^3.4.21",
    "vue-i18n": "^9.14.5",
    "vue-router": "^4.3.0",
    "vue-tsc": "^2.0.6"
  }
}
